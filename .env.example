# OpenRouter API key for WARP🔹CMD chat (https://openrouter.ai/keys)
# All model calls route through OpenRouter — never directly to provider APIs.
OPENROUTER_API_KEY=sk-or-v1-...

# Supabase project URL and anon key (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Supabase service-role key (server-only, never expose to the browser)
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# Optional: site URL used in OpenRouter attribution headers (HTTP-Referer).
# Defaults to https://warp-codx.replit.app if unset.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Phase 3a — Constitution auto-fetch.
# Fine-grained GitHub PAT, scoped `contents:read` on bayuewalker/walkermind-os.
# Server-only. Never logged, never echoed to the client.
GITHUB_PAT_CONSTITUTION=github_pat_...

# Optional: enable GET /api/debug/constitution-stats and the
# /api/constitution/clear + /api/constitution/test-pat admin endpoints in
# production. Always enabled outside production.
# DEBUG_CONSTITUTION_STATS=1

# Optional: shared secret to authorize /api/constitution/clear and
# /api/constitution/test-pat from the Settings panel in production. When
# set, the client must send `x-warp-admin-token: <value>` on the request.
# WARP_ADMIN_TOKEN=changeme
